generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Analysis {
  id                      String   @id @default(cuid())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  userId                  String?
  user                    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  fileName                String?
  template                String
  product                 String
  label                   String
  description             String
  documentType            String
  riskScore               Int
  riskLevel               String
  summary                 String

  matchedKeywords         Json
  missingRequiredKeywords Json
  forbiddenKeywordHits    Json
  issues                  Json
  deadlines               Json
  metadata                Json

  @@index([userId, createdAt])
}

enum UserPlan {
  FREE       // legacy — treated as INACTIVE in billing logic
  STARTER    // $9.99/month — 10 analyses/month
  PRO        // $29.99/month — 50 analyses/month
  UNLIMITED  // legacy — treated as PRO in billing logic
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  CANCELED
  PAST_DUE
}

model User {
  id                     String             @id @default(cuid())
  name                   String?
  email                  String             @unique
  password               String
  plan                   UserPlan           @default(FREE)
  subscriptionStatus     SubscriptionStatus @default(INACTIVE)
  stripeCustomerId       String?            @unique
  stripeSubId            String?            @unique
  currentPeriodEnd       DateTime?
  trialEndsAt            DateTime?
  addonAnalysesRemaining Int                @default(0)
  billingCycleStart      DateTime?
  sessionVersion         Int                @default(0)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  usageRecords           UsageRecord[]
  analyses               Analysis[]
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  action    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Stores fixed-window rate limit counters per (key, windowStart).
// A raw atomic upsert increments count; old windows are cleaned up lazily.
model RateLimit {
  key         String
  windowStart DateTime
  count       Int      @default(1)

  @@id([key, windowStart])
  @@index([key])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
